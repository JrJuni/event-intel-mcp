# Copy to .env and fill in. .env is gitignored.

# ---- LLM provider (choose one) ----
# Option A: Anthropic Claude (default, set llm.provider=anthropic in config)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: ChatGPT Plus/Pro subscription via OAuth (set llm.provider=chatgpt_oauth in config)
# No key needed here — first use opens a browser for ChatGPT login.
# Tokens are cached at ~/.event-intel/chatgpt_auth.json.
# To switch: add llm.provider: chatgpt_oauth to ~/.event-intel/config.yaml

# Brave Search API — required for build_event_tier_list enrichment
BRAVE_API_KEY=...

# Optional overrides
# EVENT_INTEL_HOME=~/.event-intel
# EVENT_INTEL_CHROMA_DIR=~/.event-intel/chroma
