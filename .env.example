# Copy to .env and fill in. .env is gitignored.

# ---- LLM provider (choose one) ----
# Option A: Anthropic Claude (default, set llm.provider=anthropic in config)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI official API (set llm.provider=openai in config)
# Key-based, remote/team-safe. Override the model via llm.openai_model (default gpt-4.1).
OPENAI_API_KEY=sk-...

# Option C: ChatGPT Plus/Pro subscription via OAuth (set llm.provider=chatgpt_oauth in config)
# No key needed here — first use opens a browser for ChatGPT login.
# Tokens are cached at ~/.event-intel/chatgpt_auth.json.
# Personal-local only — disabled in remote/team deploy (Y2.2).
# To switch: add llm.provider: chatgpt_oauth to ~/.event-intel/config.yaml

# ---- Search backend for build_event_tier_list enrichment ----
# Default is `ddgs` (DuckDuckGo, keyless zero-config) — nothing to set here.
# To switch backend, set in ~/.event-intel/config.yaml:
#   search.provider: ddgs      # keyless, best-effort (unofficial, rate-limited)
#   search.provider: searxng   # + search.searxng_url: http://your-instance:8888 (self-hosted)
#   search.provider: brave     # reliable, needs the key below (free tier ~2k/mo)
# BRAVE_API_KEY is ONLY used when search.provider=brave.
# BRAVE_API_KEY=...

# Deploy mode (Y2.2b): personal-local (default) | remote
# remote disables the personal-local ChatGPT OAuth lane (key-based providers only).
# EVENT_INTEL_DEPLOY_MODE=personal-local

# Transport (Y2.2c): stdio (default, Claude Desktop/CLI) | streamable-http (opt-in)
# streamable-http binds 127.0.0.1 by default and has NO built-in auth yet (Y2.2d) —
# do not bind a public host until the auth layer lands; front it with an
# authenticating reverse proxy that terminates TLS.
# EVENT_INTEL_TRANSPORT=stdio
# EVENT_INTEL_HTTP_HOST=127.0.0.1
# EVENT_INTEL_HTTP_PORT=8000
# EVENT_INTEL_HTTP_ALLOWED_HOSTS=          # comma list; default = localhost allowlist
# EVENT_INTEL_HTTP_ALLOWED_ORIGINS=        # comma list; default = localhost allowlist

# Optional overrides
# EVENT_INTEL_HOME=~/.event-intel
# EVENT_INTEL_CHROMA_DIR=~/.event-intel/chroma
