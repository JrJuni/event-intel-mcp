# Y1A benchmark — raw captured exhibitor sources may contain PII
# (officer names / contact info alongside company names). Never commit them.
sources/
# raw LLM/Brave responses + intermediate run artifacts (copyright/PII) — CS5.
# committed CI fixtures are structure-preserving synthetic, kept elsewhere.
_raw/
# working labeling artifacts (sheets/worksheets/drafts) carry raw exhibitor
# descriptions (copyright) — local only, never committed (L5 / review R1#4·R2#6).
_local/
# R2 smoke-batch run artifacts (tier lists / run summaries with raw exhibitor
# descriptions) — regenerable, local only. The pair SPEC (r2_pairs.yaml) is committed.
smoke/
# keep gold labels (company names + labels only, no PII) and run summaries.
!gold/
!runs/
!README.md
!.gitignore
# …but within gold/, the sheet/worksheet/draft artifacts still carry raw
# descriptions — re-ignore them; only sealed_labels / roster / measure_report /
# threshold manifests are committable.
gold/**/labeling_sheet.json
gold/**/worksheet.md
gold/**/ai_labels.json
gold/**/labels_TEMPLATE.json
gold/**/drafted*.json
gold/**/refined*.json
# company_packet is names-only (not sensitive) but a regenerable intermediate —
# keep gold/ to the canonical artifacts (roster / sealed_labels / measure_*).
gold/**/company_packet.json
